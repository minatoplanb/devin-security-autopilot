# Cognition Take-Home — Environment Variables
# Copy this to .env and fill in your values

# GitHub Personal Access Token (needs repo + issues permissions)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Your GitHub username or org where Superset fork lives
GITHUB_OWNER=minatoplanb

# Name of the forked Superset repo
GITHUB_REPO=superset

# Devin API Key (from enterprise workspace "Asmar DE Take Home")
DEVIN_API_KEY=your_devin_api_key_here

# Dashboard port
PORT=3000
